# =====================================
# Application Configuration
# =====================================
NODE_ENV=production
APP_NAME=Flutter-NestJS-App
APP_VERSION=1.0.0
PORT=3000

# =====================================
# Database Configuration
# =====================================
DB_HOST=database
DB_PORT=5432
DB_NAME=appdb
DB_USER=appuser
# IMPORTANT: Generate a strong password (min 32 characters)
# Example: openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# Database URL for Prisma/TypeORM
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# PostgreSQL Advanced Settings
POSTGRES_MAX_CONNECTIONS=100

# =====================================
# Redis Configuration
# =====================================
REDIS_HOST=redis
REDIS_PORT=6379
# IMPORTANT: Generate a strong password (min 32 characters)
# Example: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# =====================================
# Authentication & Security
# =====================================
# IMPORTANT: Generate strong secrets for your application
# Example: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_STRONG_SECRET
JWT_EXPIRES_IN=24h
API_SECRET_KEY=CHANGE_ME_TO_STRONG_SECRET
REFRESH_TOKEN_SECRET=CHANGE_ME_TO_STRONG_SECRET
ENCRYPTION_KEY=CHANGE_ME_TO_STRONG_SECRET
SESSION_SECRET=CHANGE_ME_TO_STRONG_SECRET

# API Keys (if needed)
# API_KEY=your_api_key_here
# GOOGLE_API_KEY=your_google_api_key

# External Service Configuration (if needed)
# API_KEY=your_api_key_here
# SMTP_PASSWORD=your_smtp_password_here

# Security Headers (optional)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Logging
LOG_LEVEL=info

# Session Configuration
SESSION_SECRET=CHANGE_ME_TO_STRONG_SECRET

# ============================================
# PASSWORD GENERATION COMMANDS
# ============================================
# Run these commands to generate secure passwords:
#
# DB_PASSWORD:
#   openssl rand -base64 32 | tr -d "=+/" | cut -c1-32
#
# REDIS_PASSWORD:
#   openssl rand -base64 32 | tr -d "=+/" | cut -c1-32
#
# JWT_SECRET:
#   openssl rand -hex 64
#
# API_SECRET_KEY:
#   openssl rand -hex 64
#
# SESSION_SECRET:
#   openssl rand -hex 64
# ============================================